generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id          String   @id @default(uuid())
  name        String
  description String?
  rooms       Room[]
  createdAt   DateTime @default(now())
}

model Room {
  id          String    @id @default(uuid())
  name        String
  description String
  price       Float
  images      String[]
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id])
  bookings    Booking[]
  createdAt   DateTime  @default(now())
}

model Booking {
  id         String   @id @default(uuid())
  userId     String?
  roomId     String
  room       Room     @relation(fields: [roomId], references: [id])
  checkIn    DateTime
  checkOut   DateTime
  totalPrice Float
  guestName  String?
  guestEmail String?
  guestPhone String?
  guests     Int      @default(1)
  status     String   @default("pending")
  createdAt  DateTime @default(now())
}

model GalleryImage {
  id        String   @id @default(uuid())
  url       String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}
